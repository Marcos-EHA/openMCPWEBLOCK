### Archivo: `src/commands/mcp/mcp.tsx`
```typescript
// ✅ Nuevo componente MCPSetMode
function MCPSetMode({ mode, onComplete })

// ✅ Nuevo dispatch en función call()
if (parts[0] === 'set-mode' && parts[1] && ['api', 'web', 'auto'].includes(parts[1]))
  return <MCPSetMode mode={parts[1]} onComplete={onDone} />
```

### Archivo: `src/tools.ts`
```typescript
// ✅ Importación de config
import { getCurrentProjectConfig } from './utils/config.js'

// ✅ Lógica de filtrado por modo en assembleToolPool()
const mode = config.mcpExecutionMode || 'api'

if (mode === 'api') {
  allowedMcpTools = []  // Solo built-in
} else if (mode === 'web') {
  allowedMcpTools = allowedMcpTools.filter(tool =>
    tool.mcpInfo?.serverName === 'superassistant-proxy'
  )
} else if (mode === 'auto') {
  // Todas las herramientas
}
```

